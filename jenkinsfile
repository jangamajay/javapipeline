pipeline {
    agent any

    stages {

        stage('checkout') {
            steps {
                checkout scm
            }
        }

        stage('test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('package') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('deploy') {
            steps {
                script {
                    def userChoice = input(
                        message: 'Do you want to deploy the project?',
                        parameters: [choice(name: 'Proceed', choices: 'Yes\nNo')]
                    )

                    if (userChoice == 'Yes') {
                        sh '''
                        echo "Deploying application..."
                        '''
                    } else {
                        error("Deployment aborted by user")
                    }
                }
            }
        }

    }
}
